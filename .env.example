# PolyTool Local Development Environment
# Copy this file to .env and customize as needed.
# Use placeholders only. Never commit real secrets.

# ClickHouse (docker-compose + host-side CLI defaults)
# Note: the current init SQL assumes the default "polytool" database.
# Set CLICKHOUSE_PASSWORD in .env before first `docker compose up`.
# Host-side CLI tools read the same .env values when run from the repo root.
# If you change CLICKHOUSE_USER / CLICKHOUSE_PASSWORD after ClickHouse has initialized,
# recreate the ClickHouse volume so the server user matches the local client config.
CLICKHOUSE_DB=polytool
CLICKHOUSE_USER=polytool_admin
CLICKHOUSE_PASSWORD=admin
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000

# Optional host-side overrides for CLI tools.
# Leave commented for normal Docker usage.
# CLICKHOUSE_HOST=localhost
# CLICKHOUSE_PORT=8123
# CLICKHOUSE_DATABASE=polytool
# POLYTOOL_IN_DOCKER=1

# Grafana
# Legacy GRAFANA_CH_USER / GRAFANA_CH_PASSWORD were removed:
# datasource credentials are provisioned under infra/grafana/ and ClickHouse init SQL.
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# API / service ports and upstreams
API_PORT=8000
SIMTRADER_STUDIO_PORT=8765
API_BASE_URL=http://localhost:8000
GAMMA_API_BASE=https://gamma-api.polymarket.com
DATA_API_BASE=https://data-api.polymarket.com
CLOB_API_BASE=https://clob.polymarket.com
INGEST_MAX_PAGES_DEFAULT=50
HTTP_TIMEOUT_SECONDS=20

# Resolution enrichment
POLYGON_RPC_URL=https://polygon-rpc.com
POLYMARKET_SUBGRAPH_URL=https://api.thegraph.com/subgraphs/name/polymarket/polymarket-matic
RESOLUTION_RPC_TIMEOUT_SECONDS=10
RESOLUTION_SUBGRAPH_TIMEOUT_SECONDS=15

# PnL / arb / orderbook / opportunities
PNL_BUCKET_DEFAULT=day
PNL_ORDERBOOK_CACHE_SECONDS=30
PNL_MAX_TOKENS_PER_RUN=200
PNL_HTTP_TIMEOUT_SECONDS=20
ARB_CACHE_SECONDS=30
ARB_MAX_TOKENS_PER_RUN=200
BOOK_SNAPSHOT_DEPTH_BAND_BPS=50
BOOK_SNAPSHOT_NOTIONALS=100,500
BOOK_SNAPSHOT_MAX_TOKENS=200
BOOK_SNAPSHOT_MIN_OK_TARGET=5
BOOK_SNAPSHOT_404_TTL_HOURS=24
BOOK_SNAPSHOT_MAX_PREFLIGHT=200
ORDERBOOK_SNAPSHOT_MAX_AGE_SECONDS=3600
OPPORTUNITY_TRADE_LOOKBACK_DAYS=90
OPPORTUNITY_SNAPSHOT_MAX_AGE_SECONDS=3600

# Scan runner defaults
TARGET_USER=@example_user
SCAN_MAX_PAGES=50
SCAN_BUCKET=day
SCAN_BACKFILL=true
SCAN_INGEST_MARKETS=false
SCAN_INGEST_ACTIVITY=false
SCAN_INGEST_POSITIONS=false
SCAN_COMPUTE_PNL=false
SCAN_COMPUTE_OPPORTUNITIES=false
SCAN_SNAPSHOT_BOOKS=false
SCAN_ENRICH_RESOLUTIONS=false
SCAN_COMPUTE_CLV=false
SCAN_WARM_CLV_CACHE=false
SCAN_CLV_OFFLINE=false
SCAN_CLV_WINDOW_MINUTES=1440
SCAN_CLV_INTERVAL=1m
SCAN_CLV_FIDELITY=1
SCAN_RESOLUTION_MAX_CANDIDATES=500
SCAN_RESOLUTION_BATCH_SIZE=25
SCAN_RESOLUTION_MAX_CONCURRENCY=4
SCAN_HTTP_TIMEOUT_SECONDS=120
SCAN_DEBUG_EXPORT=false

# Live execution credentials (optional; required only for --live / CLOB auth)
PK=replace_with_wallet_private_key_hex_no_0x
CLOB_API_KEY=replace_with_clob_api_key
CLOB_API_SECRET=replace_with_clob_api_secret
CLOB_API_PASSPHRASE=replace_with_clob_api_passphrase

# Optional alternative CLOB auth inputs for scan/CLV requests.
# Prefer the derived CLOB_API_* credentials above unless you know you need one of these.
# CLOB_API_BEARER_TOKEN=replace_with_bearer_token
# CLOB_X_API_KEY=replace_with_x_api_key
# CLOB_AUTH_HEADER=Authorization
# CLOB_AUTH_VALUE=Bearer replace_with_bearer_token

# Optional tooling overrides
# POLYTOOL_ARTIFACTS_ROOT=artifacts
# PNL_BUCKET=day
# ARB_MAX_TOKENS_SMOKE=50
