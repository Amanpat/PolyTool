      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse-polytool"
          },
          "editorType": "sql",
          "format": 1,
          "meta": {
            "builderOptions": {
              "columns": [],
              "database": "polytool",
              "limit": 1000,
              "mode": "list",
              "queryType": "table",
              "table": "n8n_execution_metrics"
            }
          },
          "queryType": "sql",
          "rawSql": "SELECT\n  workflow_name,\n  argMax(status, started_at)           AS last_status,\n  max(started_at)                      AS last_run_at,\n  round(argMax(duration_seconds, started_at), 1) AS last_duration_sec\nFROM polytool.n8n_execution_metrics FINAL\nWHERE started_at >= now() - INTERVAL 7 DAY\nGROUP BY workflow_name\nORDER BY last_run_at DESC",
          "refId": "A"
        }
      ],
      "title": "Latest Run Status per Workflow",
      "type": "table"
    }
