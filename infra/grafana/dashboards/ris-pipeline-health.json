              "table": "n8n_execution_metrics"
            }
          },
          "queryType": "timeseries",
          "rawSql": "SELECT\n  toStartOfHour(started_at) AS time,\n  round(\n    countIf(status = 'success') * 100.0 / count(),\n    1\n  ) AS success_rate_pct\nFROM polytool.n8n_execution_metrics FINAL\nWHERE $__timeFilter(started_at)\nGROUP BY time\nORDER BY time",
          "refId": "A"
        }
      ],
      "title": "Execution Success Rate",
      "type": "timeseries"
    },
