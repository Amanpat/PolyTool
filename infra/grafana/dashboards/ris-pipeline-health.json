              "queryType": "table",
              "table": "n8n_execution_metrics"
            }
          },
          "queryType": "sql",
          "rawSql": "SELECT\n  workflow_name,\n  countIf(status IN ('error', 'crashed')) AS failure_count\nFROM polytool.n8n_execution_metrics FINAL\nWHERE $__timeFilter(started_at)\nGROUP BY workflow_name\nORDER BY failure_count DESC",
          "refId": "A"
        }
      ],
      "title": "Failure Count by Workflow",
