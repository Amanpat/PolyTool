            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": false,
  "settings": {
    "executionOrder": "v1"
  },
  "meta": {
    "instanceId": "polytool-ris-pilot",
    "templateCredsSetupCompleted": true
  },
  "pinData": {},
  "staticData": null,
  "tags": [
