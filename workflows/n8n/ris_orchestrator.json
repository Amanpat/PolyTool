            "type": "main",
            "index": 0
          }
        ],
        []
      ]
    },
    "RIS Trigger Webhook": {
      "main": [
        [
          {
            "node": "Switch Pipeline",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Switch Pipeline": {
      "main": [
        [
          {
            "node": "Exec Academic",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Exec Reddit",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Exec Blog",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Exec YouTube",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Exec GitHub",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Exec Digest",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Exec Freshness",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "RIS Ingest Webhook": {
      "main": [
        [
          {
            "node": "Run research-acquire",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Run research-acquire": {
      "main": [
        [
          {
