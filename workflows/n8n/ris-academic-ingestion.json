{
  "name": "RIS Academic Ingestion",
  "nodes": [
    {
      "parameters": {
        "content": "ArXiv paper ingestion - every 12h"
      },
      "id": "a1b2c3d4-e5f6-7890-abcd-000000000001",
      "name": "Sticky Note",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [240, 100]
    },
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "hours",
              "hoursInterval": 12
            }
          ]
        }
      },
      "id": "a1b2c3d4-e5f6-7890-abcd-000000000002",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [240, 300]
    },
    {
      "parameters": {
        "command": "docker exec polytool-polytool-1 python -m polytool research-scheduler run-job academic_ingest"
      },
      "id": "a1b2c3d4-e5f6-7890-abcd-000000000003",
      "name": "Run academic_ingest",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [500, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": ""
          },
          "conditions": [
            {
              "id": "a1b2c3d4-e5f6-7890-abcd-000000000011",
              "leftValue": "={{ $json.exitCode }}",
              "rightValue": 0,
              "operator": {
                "type": "number",
                "operation": "notEquals"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "a1b2c3d4-e5f6-7890-abcd-000000000004",
      "name": "IF",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [760, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.DISCORD_WEBHOOK_URL }}",
        "sendBody": true,
        "contentType": "json",
        "body": "={\n  \"content\": \"RIS Pipeline Alert\",\n  \"embeds\": [{\n    \"title\": \"Workflow Failed: RIS Academic Ingestion\",\n    \"description\": \"Exit code: {{ $('Run academic_ingest').item.json.exitCode }}\\nStderr: {{ $('Run academic_ingest').item.json.stderr.substring(0, 500) }}\",\n    \"color\": 16711680\n  }]\n}"
      },
      "id": "a1b2c3d4-e5f6-7890-abcd-000000000005",
      "name": "Discord Alert",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1020, 200]
    }
  ],
  "connections": {
    "Schedule Trigger": {
      "main": [
        [
          {
            "node": "Run academic_ingest",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Run academic_ingest": {
      "main": [
        [
          {
            "node": "IF",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "IF": {
      "main": [
        [
          {
            "node": "Discord Alert",
            "type": "main",
            "index": 0
          }
        ],
        []
      ]
    }
  },
  "active": true,
  "settings": {
    "executionOrder": "v1"
  },
  "id": "ris-academic-ingestion-v2",
  "meta": {
    "instanceId": "polytool-ris-v2"
  },
  "pinData": {},
  "staticData": null
}
