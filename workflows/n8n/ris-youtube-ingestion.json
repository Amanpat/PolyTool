{
  "name": "RIS YouTube Ingestion",
  "nodes": [
    {
      "parameters": {
        "content": "YouTube ingestion - weekly Monday 04:00"
      },
      "id": "d4e5f6a7-b8c9-0123-defa-000000000001",
      "name": "Sticky Note",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [240, 100]
    },
    {
      "parameters": {
        "rule": {
          "cronExpression": "0 4 * * 1"
        }
      },
      "id": "d4e5f6a7-b8c9-0123-defa-000000000002",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [240, 300]
    },
    {
      "parameters": {
        "command": "docker exec polytool-polytool-1 python -m polytool research-scheduler run-job youtube_ingest"
      },
      "id": "d4e5f6a7-b8c9-0123-defa-000000000003",
      "name": "Run youtube_ingest",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [500, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": ""
          },
          "conditions": [
            {
              "id": "d4e5f6a7-b8c9-0123-defa-000000000011",
              "leftValue": "={{ $json.exitCode }}",
              "rightValue": 0,
              "operator": {
                "type": "number",
                "operation": "notEquals"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "d4e5f6a7-b8c9-0123-defa-000000000004",
      "name": "IF",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [760, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.DISCORD_WEBHOOK_URL }}",
        "sendBody": true,
        "contentType": "json",
        "body": "={\n  \"content\": \"RIS Pipeline Alert\",\n  \"embeds\": [{\n    \"title\": \"Workflow Failed: RIS YouTube Ingestion\",\n    \"description\": \"Exit code: {{ $('Run youtube_ingest').item.json.exitCode }}\\nStderr: {{ $('Run youtube_ingest').item.json.stderr.substring(0, 500) }}\",\n    \"color\": 16711680\n  }]\n}"
      },
      "id": "d4e5f6a7-b8c9-0123-defa-000000000005",
      "name": "Discord Alert",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1020, 200]
    }
  ],
  "connections": {
    "Schedule Trigger": {
      "main": [
        [
          {
            "node": "Run youtube_ingest",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Run youtube_ingest": {
      "main": [
        [
          {
            "node": "IF",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "IF": {
      "main": [
        [
          {
            "node": "Discord Alert",
            "type": "main",
            "index": 0
          }
        ],
        []
      ]
    }
  },
  "active": true,
  "settings": {
    "executionOrder": "v1"
  },
  "id": "ris-youtube-ingestion-v2",
  "meta": {
    "instanceId": "polytool-ris-v2"
  },
  "pinData": {},
  "staticData": null
}
