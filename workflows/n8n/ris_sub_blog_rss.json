{
  "name": "RIS Sub: Blog/RSS",
  "nodes": [
    {
      "id": "blog-sticky",
      "name": "Sticky Note",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [80, 160],
      "parameters": {
        "content": "## RIS Sub: Blog/RSS Ingest\n**Schedule:** Every 4 hours\n**Command:** `research-scheduler run-job blog_ingest`\n\n**Flow:** Trigger -> Execute Command [continueOnFail] -> IF exit code 0\n- Success: Parse metrics\n- Failure: Format error -> Discord alert",
        "height": 180,
        "width": 400
      }
    },
    {
      "id": "blog-manual",
      "name": "Manual Trigger",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [240, 400],
      "parameters": {}
    },
    {
      "id": "blog-schedule",
      "name": "Every 4 Hours",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [240, 560],
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "hours",
              "hoursInterval": 4
            }
          ]
        }
      }
    },
    {
      "id": "blog-exec",
      "name": "Run blog_ingest",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [500, 480],
      "parameters": {
        "command": "docker exec polytool-ris-scheduler python -m polytool research-scheduler run-job blog_ingest"
      },
      "continueOnFail": true
    },
    {
      "id": "blog-if",
      "name": "IF Exit Code OK",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [760, 480],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "exitcode-check",
              "leftValue": "={{ $json.exitCode }}",
              "rightValue": 0,
              "operator": {
                "type": "number",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      }
    },
    {
      "id": "blog-parse",
      "name": "Parse Metrics",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1020, 360],
      "parameters": {
        "jsCode": "const stdout = $('Run blog_ingest').first().json.stdout || '';\nconst lines = stdout.split('\\n').filter(l => l.trim());\nconst timestamp = new Date().toISOString();\nreturn [{ json: { status: 'success', job: 'blog_ingest', stdout: stdout.substring(0, 1500), lineCount: lines.length, timestamp } }];"
      }
    },
    {
      "id": "blog-success",
      "name": "Success",
      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1,
      "position": [1280, 360],
      "parameters": {}
    },
    {
      "id": "blog-format-error",
      "name": "Format Error",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1020, 600],
      "parameters": {
        "jsCode": "const execNode = $('Run blog_ingest').first().json;\nconst stderr = (execNode.stderr || '').substring(0, 1500);\nconst stdout = (execNode.stdout || '');\nconst exitCode = execNode.exitCode;\nconst content = `**RIS Pipeline Error: blog_ingest**\\n\\nExit code: ${exitCode}\\n\\n**stderr:**\\n\\`\\`\\`\\n${stderr}\\n\\`\\`\\`\\n\\n**stdout (last 500 chars):**\\n\\`\\`\\`\\n${stdout.substring(stdout.length - 500)}\\n\\`\\`\\``;\nreturn [{ json: { content } }];"
      }
    },
    {
      "id": "blog-discord",
      "name": "Discord Alert",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1280, 600],
      "parameters": {
        "method": "POST",
        "url": "={{ $env.DISCORD_WEBHOOK_URL }}",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ content: $json.content }) }}"
      },
      "continueOnFail": true
    }
  ],
  "connections": {
    "Manual Trigger": {
      "main": [[{"node": "Run blog_ingest", "type": "main", "index": 0}]]
    },
    "Every 4 Hours": {
      "main": [[{"node": "Run blog_ingest", "type": "main", "index": 0}]]
    },
    "Run blog_ingest": {
      "main": [[{"node": "IF Exit Code OK", "type": "main", "index": 0}]]
    },
    "IF Exit Code OK": {
      "main": [
        [{"node": "Parse Metrics", "type": "main", "index": 0}],
        [{"node": "Format Error", "type": "main", "index": 0}]
      ]
    },
    "Parse Metrics": {
      "main": [[{"node": "Success", "type": "main", "index": 0}]]
    },
    "Format Error": {
      "main": [[{"node": "Discord Alert", "type": "main", "index": 0}]]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}
